# vim: ft=ghostty

config-file = ?theme

#config-file = keybinds/regular
config-file = keybinds/tmux

auto-update = off
copy-on-select = clipboard
shell-integration = none
shell-integration-features = false

fullscreen = false
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true

macos-icon = retro
macos-option-as-alt = left

font-size = 14
font-thicken = true
font-thicken-strength = 1
#cursor-invert-fg-bg = false

adjust-cell-height = 2
adjust-cursor-height = 2
font-feature = -calt, -liga, -dlig

# font-family = "Hack"
# font-family = "Meslo LG S"
# font-family = "Iosevka Fixed"
font-family = "Source Code Pro"

# custom-shader = shaders/smear.glsl

config-file = ?local-config
