# vim: ft=ghostty

config-file = ?theme

#config-file = keybinds/regular
config-file = keybinds/tmux

auto-update = off
copy-on-select = clipboard
shell-integration = none
shell-integration-features = false

fullscreen = false
window-theme = dark
window-padding-x = 4
window-padding-y = 4
window-padding-balance = true

macos-icon = retro
macos-option-as-alt = left

background-opacity = 0.95
background-opacity-cells = true
background-blur = true

font-size = 14
font-thicken = true
font-thicken-strength = 0
#cursor-invert-fg-bg = true

#adjust-cell-height = 2
#adjust-cursor-height = 2
font-feature = -calt, -liga, -dlig

font-family = "Hack"

# custom-shader = shaders/smear.glsl

config-file = ?local-config
