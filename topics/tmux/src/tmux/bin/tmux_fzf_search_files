#!/usr/bin/env bash

# $1 = pane_current_path
# $2 = pane_current_command

cd "$1" || exit 1

if read -t 0 _; then
    # read stdin
    readarray lines
else
    # no stdin
    exit 2
fi

files=()
while read -r line; do
    p="${line/\~/$HOME}"
    if [[ -f "$p" ]] && file "$p" | grep -q 'text'; then
        files+=("$p")
    fi
done < <(printf '%s\n' "${lines[@]}" | xargs -0 | tr ' ' '\n' | sort | uniq)

[[ -n "${files[*]}" ]] || {
    tmux display-message "no files found"
    exit 0
}

if ! choice="$(echo "${files[@]}" | xargs | tr ' ' '\n' | sort | uniq | sort -r | fzf --tmux)"; then
    exit 0
fi

p="${choice/\~/$HOME}"
if [[ -f "$p" ]]; then
    if [[ "$2" =~ ^(sh|bash|zsh|fish)$ ]]; then
        tmux send-keys C-a C-k "nvim '$p'" Enter
    else
        tmux display-message "current prompt busy with '$2'"
    fi
fi
